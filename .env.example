# =============================================================================
# AgentGuard Configuration
# Copy to .env and fill in values
# =============================================================================

# --- Application ---
APP_NAME=AgentGuard
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# --- Authentication ---
API_KEY_HEADER=X-API-Key               # Header name for API key auth
JWT_SECRET=change-me-in-production     # JWT signing secret (required in production)
JWT_ALGORITHM=HS256

# --- Tenant ---
DEFAULT_TENANT_ID=default              # Fallback tenant when none specified
TENANT_HEADER=X-Tenant-ID             # Header name for tenant identification

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60     # Per-tenant request limit
RATE_LIMIT_BACKEND=memory              # memory | redis

# --- Redis (optional, for rate limiting and caching) ---
REDIS_URL=redis://localhost:6379/0

# --- Database (for audit logs) ---
DATABASE_URL=postgresql://agentguard:agentguard@localhost:5432/agentguard

# --- Model Providers ---
OPENAI_API_KEY=                        # OpenAI API key
ANTHROPIC_API_KEY=                     # Anthropic API key
DEFAULT_MODEL_PROVIDER=openai          # openai | anthropic | local
DEFAULT_MODEL_NAME=gpt-4o

# --- Policy ---
POLICY_DIR=policies                    # Directory containing policy YAML files
DEFAULT_POLICY=default                 # Default policy file name (without .yaml)

# --- Prompt Packages ---
PROMPT_PACKAGES_DIR=prompt_packages    # Directory containing prompt package definitions

# --- Guardrails ---
INPUT_GUARDRAILS_ENABLED=true
OUTPUT_VALIDATION_ENABLED=true
ACTION_GOVERNANCE_ENABLED=true

# --- Slop Score ---
SLOP_SCORE_THRESHOLD_PASS=0.3         # Below this: pass
SLOP_SCORE_THRESHOLD_REPAIR=0.7       # Between pass and this: repair; above: reject

# --- Observability ---
ENABLE_AUDIT_LOG=true
ENABLE_REQUEST_TRACING=true
ENABLE_QUALITY_RISK_METRICS=false   # increment in-memory counters on each compute_slop_score()
CORS_ORIGINS=["http://localhost:3000"]
